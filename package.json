{
	"name": "gatherpress-export-import",
	"version": "0.3.0",
	"description": "Intercepts WordPress XML imports from third-party event plugins and transforms them into GatherPress data automatically.",
	"author": "Carsten Bach & WordPress Telex",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"tickets",
		"gatherpress",
		"events"
	],
	"homepage": "https://github.com/carstingaxion/gatherpress-export-import#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/carstingaxion/gatherpress-export-import.git"
	},
	"bugs": {
		"url": "https://github.com/carstingaxion/gatherpress-export-import/issues"
	},
	"main": "build/index.js",
	"devDependencies": {
		"@wordpress/env": "^10.39.0",
		"@wordpress/scripts": "^30.15.0"
	},
	"scripts": {
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:css:fix": "wp-scripts lint-style --fix",
		"lint:js": "wp-scripts lint-js",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:md:js": "wp-scripts lint-md-js",
		"lint:php": "vendor/bin/phpcs --standard=.phpcs.xml --extensions=php --colors -s -p -v .",
		"lint:php:fix": "vendor/bin/phpcbf --standard=.phpcs.xml -p -v .",
		"lint:phpstan": "vendor/bin/phpstan analyze -vv --memory-limit=2G",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy",
		"pretest:php": "wp-env start",
		"test:php": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-export-import' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit'",
		"test:php:unit": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-export-import' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit --testsuite unit'",
		"test:php:integration": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-export-import' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit --testsuite integration'"
	}
}
