<?xml version="1.0"?>
<ruleset name="gatherpress-export-import">
	<description>Coding standards for gatherpress-export-import</description>

	<file>.</file>
	<arg name="basepath" value="./"/><!-- Strip the file paths down to the relevant bit -->

	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<exclude-pattern>*/wp-content/*</exclude-pattern>
	<exclude-pattern>.wordpress-org/*</exclude-pattern>
	<exclude-pattern>test/php/bootstrap.php</exclude-pattern>

	<!-- Rules: figuren.theater Coding Standards -->
	<rule ref="figurentheater" />

	<!-- Allow additional text_domains -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="gatherpress-export-import"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="gpei_"/>
				<element value="GatherPressExportImport"/>
				<element value="__NAMESPACE__"/>
			</property>

		</properties>
	</rule>
	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
		<exclude name="Universal.PHP.RequireExitDieParentheses.Missing" />
		<exclude name="Universal.Classes.RequireFinalClass.NonFinalClassFound" />
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed" />

		<!-- Allow slow meta queries - because migrations happen once and that's how it works ;) -->
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_key" />
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_value" />
	</rule>

	<!-- Allow uncached queries - because migrations happen once and stuff shouldn't be cached -->
	<rule ref="WordPressVIPMinimum">
		<exclude name="WordPressVIPMinimum.Functions.RestrictedFunctions.get_posts_get_posts" />
	</rule>

	<rule ref="Generic.Files.OneObjectStructurePerFile.MultipleFound">
		<exclude-pattern>test/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
		<exclude-pattern>test/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.DB.SlowDBQuery.slow_db_query_meta_key">
		<exclude-pattern>test/*</exclude-pattern>
	</rule>
	<rule ref="WordPressVIPMinimum.Performance.FetchingRemoteData.FileGetContentsUnknown">
		<exclude-pattern>test/*</exclude-pattern>
	</rule>


</ruleset>
