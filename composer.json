{
    "name": "carstingaxion/gatherpress-export-import",
    "description": "Intercepts WordPress XML imports from third-party event plugins and transforms them into GatherPress data automatically.",
    "license": "GPL-2.0+",
    "type": "wordpress-plugin",
    "keywords": [
        "wordpress",
        "wordpress-plugin",
        "gatherpress"
    ],
    "authors": [
        {
            "name": "figuren.theater",
            "email": "info@figuren.theater"
        },
        {
            "name": "Carsten Bach",
            "email": "mail@carsten-bach.de",
            "homepage": "https://carsten-bach.de",
            "role": "Developer"
        }
    ],
    "homepage": "https://websites.fuer.figuren.theater",
    "support": {
        "email": "info@figuren.theater",
        "issues": "https://github.com/carstingaxion/gatherpress-export-import/issues",
        "source": "https://github.com/carstingaxion/gatherpress-export-import"
    },
    "require-dev": {
        "akirk/extract-wp-hooks": "dev-main",
        "figuren-theater/code-quality": "*",
        "phpunit/phpunit": "9.6",
        "wp-phpunit/wp-phpunit": "^6.9",
        "wpackagist-plugin/gatherpress": "*",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        },
        {
            "type": "vcs",
            "url": "git@github.com:akirk/extract-wp-hooks.git"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "figuren-theater/altis-core": true,
            "figuren-theater/ft-core": true,
            "koodimonni/composer-dropin-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "altis": {
            "install-overrides": []
        }
    }
}
