{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Event Organiser — Demo Export",
		"description": "Demo site with Event Organiser data ready to export for GatherPress migration testing.",
		"author": "WordPress Telex"
	},
	"preferredVersions": {
		"php": "8.0",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"plugins": [
		"event-organiser"
	],
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Event Organiser Demo for GatherPress Migration"
			}
		},
		{
			"step": "writeFile",
			"path": "/wordpress/wp-content/mu-plugins/eo-export-helper.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/carstingaxion/gatherpress-export-import/main/.wordpress-org/blueprints/eo-export-helper.php"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once '../wordpress/wp-load.php'; flush_rewrite_rules();"
		},
		{
			"step": "writeFile",
			"path": "/tmp/event-organiser-import.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/carstingaxion/gatherpress-export-import/main/.wordpress-org/blueprints/event-organiser-import.php"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require '/tmp/event-organiser-import.php';"
		}
	],
	"landingPage": "/wp-admin/export.php"
}
