{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Events Manager — Demo Export",
		"description": "Demo site with Events Manager data ready to export for GatherPress migration testing.",
		"author": "WordPress Telex"
	},
	"preferredVersions": {
		"php": "8.0",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"plugins": [
		"events-manager"
	],
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Events Manager Demo for GatherPress Migration"
			}
		},
		{
			"step": "writeFile",
			"path": "/tmp/events-manager-import.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/carstingaxion/gatherpress-export-import/main/.wordpress-org/blueprints/events-manager-import.php"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require '/tmp/events-manager-import.php';"
		}
	],
	"landingPage": "/wp-admin/export.php"
}
