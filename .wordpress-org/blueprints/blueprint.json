{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "GatherPress Event Migration",
		"description": "Test environment for migrating event data from third-party plugins into GatherPress.",
		"author": "WordPress Telex"
	},
	"preferredVersions": {
		"php": "8.0",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"plugins": [
		"wordpress-importer",
		"gatherpress"
	],
	"steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/carstingaxion/gatherpress-export-import",
        "ref": "HEAD"
      },
      "options": {
        "activate": true
      },
      "progress": {
        "caption": "Installing plugin from GitHub: carstingaxion/gatherpress-export-import"
      }
    },
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "GatherPress Migration Test"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once 'wordpress/wp-load.php'; flush_rewrite_rules();"
		}
	],
	"landingPage": "/wp-admin/admin.php?import=gatherpress-migration"
}
